VERSION 5.5 ;
NAMESCASESENSITIVE ON ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;

DESIGN chip ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 500000 200000 ) ;

TRACKS X 4 DO 556 STEP 900 LAYER Metal5 ;
TRACKS Y 4 DO 222 STEP 900 LAYER Metal5 ;
TRACKS X 3 DO 893 STEP 560 LAYER Metal4 ;
TRACKS Y 3 DO 357 STEP 560 LAYER Metal4 ;
TRACKS X 2 DO 893 STEP 560 LAYER Metal3 ;
TRACKS Y 2 DO 357 STEP 560 LAYER Metal3 ;
TRACKS X 1 DO 893 STEP 560 LAYER Metal2 ;
TRACKS Y 1 DO 357 STEP 560 LAYER Metal2 ;
TRACKS X 0 DO 893 STEP 560 LAYER Metal1 ;
TRACKS Y 0 DO 357 STEP 560 LAYER Metal1 ;

COMPONENTS 3 ;
- I_0_0_0_0 SchottkyDiode + PLACED ( 0 0 ) N ;
- I_1_0_0_0 SchottkyDiode + PLACED ( 40000 0 ) N ;
- I_2_0_0_0 TunnelingChargePump + PLACED ( 80000 0 ) N ;
END COMPONENTS

